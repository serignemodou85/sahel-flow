        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  NOW() AS time,\n  MAX(CASE WHEN country_code = 'SEN' THEN risk_score END) AS \"SEN\",\n  MAX(CASE WHEN country_code = 'CIV' THEN risk_score END) AS \"CIV\"\nFROM marts.mart__risk__score_monthly\nWHERE period = (\n  SELECT MAX(period)\n  FROM marts.mart__risk__score_monthly\n)",
          "refId": "A"
        }
      ],
      "title": "Niveau de risque actuel",
      "type": "stat"
