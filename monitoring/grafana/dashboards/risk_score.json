          "rawQuery": true,
          "rawSql": "SELECT\n  period::timestamp AS time,\n  risk_score AS \"SEN\"\nFROM marts.mart__risk__score_monthly\nWHERE country_code = 'SEN'\n  AND period::timestamp >= $__timeFrom()\n  AND period::timestamp <= $__timeTo()\nORDER BY time",
          "refId": "A"
