        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  period::timestamp AS time,\n  price_trend_score AS \"Tendance prix (×0.6)\",\n  inflation_score   AS \"Inflation (×0.4)\",\n  risk_score        AS \"Risk Score (total)\"\nFROM marts.mart__risk__score_monthly\nWHERE country_code = '${country}'\n  AND period::timestamp >= $__timeFrom()\n  AND period::timestamp <= $__timeTo()\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Décomposition du score — ${country}",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "risk_score" },
            "properties": [
              { "id": "displayName", "value": "Risk Score" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 25 },
                    { "color": "orange", "value": 50 },
                    { "color": "red", "value": 75 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "price_trend_score" },
            "properties": [{ "id": "displayName", "value": "Tendance prix" }]
          },
          {
            "matcher": { "id": "byName", "options": "inflation_score" },
            "properties": [{ "id": "displayName", "value": "Score inflation" }]
          },
          {
            "matcher": { "id": "byName", "options": "avg_price_usd" },
            "properties": [
              { "id": "displayName", "value": "Prix moy. USD" },
              { "id": "unit", "value": "currencyUSD" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 6,
      "options": { "footer": { "show": false } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  period,\n  risk_score,\n  price_trend_score,\n  inflation_score,\n  avg_price_usd,\n  inflation_rate\nFROM marts.mart__risk__score_monthly\nWHERE country_code = '${country}'\nORDER BY period DESC\nLIMIT 36",
          "refId": "A"
        }
      ],
      "title": "Historique du score (36 derniers mois) — ${country}",
      "type": "table"
    }
