# =============================================================================
# .env.example — valeurs par défaut pour le développement local
# Copier en .env et NE JAMAIS committer .env
# =============================================================================

# ── TimescaleDB ───────────────────────────────────────────────────────────────
POSTGRES_USER=sahel
POSTGRES_PASSWORD=sahel_secret_dev     # changer en production

# ── Airflow ───────────────────────────────────────────────────────────────────
# Clé de chiffrement des connexions Airflow (tokens, mots de passe).
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Si vide : Airflow fonctionne mais les connexions chiffrées ne survivent pas au restart.
AIRFLOW_FERNET_KEY=

# Clé secrète pour les sessions web Airflow (cookies).
# Générer : openssl rand -hex 32
AIRFLOW_SECRET_KEY=change_me_in_production

# ── APIs sources ──────────────────────────────────────────────────────────────
# World Bank — public, aucune clé requise.
WB_API_BASE_URL=https://api.worldbank.org/v2

# WFP Data Bridges — token Bearer requis.
# Inscription gratuite : https://api.wfpvam.org
# Laisser vide en dev tant que le token n'est pas obtenu.
WFP_API_BASE_URL=https://api.wfpvam.org/v2
WFP_API_KEY=
